# Corellium tenant — copy to .env and fill in. .env is git-ignored.
# Host WITHOUT scheme or /api suffix (e.g. maigret.enterprise.corellium.com or app.corellium.com)
CORELLIUM_API_HOST=maigret.enterprise.corellium.com
# API token from Corellium → Settings → API Token. Bearer auth.
CORELLIUM_API_TOKEN=

# Optional: skip TLS verify for self-signed on-prem (default 0 = verify). Set to 1 only if needed.
CORELLIUM_INSECURE_TLS=0

# Eval runner (P4+) — only needed to run the evaluator, not the MCP server.
ANTHROPIC_API_KEY=
